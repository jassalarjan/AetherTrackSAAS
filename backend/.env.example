# Copy to backend/.env and fill with real values. Do not commit backend/.env.
NODE_ENV=development
PORT=5000

# Comma-separated client origins (required in production).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Use long, random secrets (minimum 32 characters).
JWT_SECRET=replace-with-a-random-32-char-or-longer-secret
JWT_REFRESH_SECRET=replace-with-a-second-random-32-char-or-longer-secret
MIN_JWT_SECRET_LENGTH=32

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Optional: deployment version signaling
APP_VERSION=1.0.0
BUILD_TIME=2026-01-01T00:00:00.000Z
APP_VERSION_NOTIFY_TOKEN=replace-with-random-token

# Optional: SMTP/Brevo configuration
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_LOGIN_EMAIL=no-reply@example.com
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=AetherTrack
EMAIL_PROVIDER=brevo
